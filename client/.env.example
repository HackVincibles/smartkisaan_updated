# ─── Backend API ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api/v1

# ─── Google OAuth ──────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Razorpay ──────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx

# ─── Polygon Blockchain (Amoy Testnet) ─────────────────────────
VITE_POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
VITE_ESCROW_CONTRACT_ADDRESS=0x_your_deployed_escrow_contract_address
VITE_REPUTATION_CONTRACT_ADDRESS=0x_your_deployed_reputation_contract_address

# ─── App ───────────────────────────────────────────────────────
VITE_APP_NAME=SmartKisan
VITE_APP_ENV=development
